# Secrets — never tracked
.env
credentials.json
*.key
*.pem

# Environments and caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Runtime artifacts
logs/
archlens.log
runs/
/graphify-out/

# Volatile test reports (regenerated each run); curated .md reports stay tracked
reports/junit.xml
reports/coverage.json
reports/*.log

# Generated notebook outputs (the source .ipynb is tracked)
notebooks/*.html
notebooks/*_executed.ipynb
notebooks/.ipynb_checkpoints/
