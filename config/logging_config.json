{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "standard": {
      "format": "%(asctime)s %(levelname)s %(name)s: %(message)s"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "standard"
    },
    "file": {
      "class": "logging.FileHandler",
      "level": "DEBUG",
      "formatter": "standard",
      "filename": "archlens.log",
      "delay": true
    }
  },
  "loggers": {
    "archlens": {
      "level": "INFO",
      "handlers": ["console", "file"],
      "propagate": false
    }
  }
}
