{
  "version": "1.00",
  "target_repo": {
    "url": "https://github.com/httpie/cli",
    "branch": "master",
    "pinned_commit": "HEAD",
    "workdir_root": "runs",
    "clone_depth": 1,
    "timeout_s": 300,
    "max_size_mb": 200
  },
  "fallback_repo": {
    "url": "https://github.com/psf/requests",
    "branch": "main",
    "pinned_commit": "HEAD",
    "workdir_root": "runs",
    "clone_depth": 1,
    "timeout_s": 300,
    "max_size_mb": 200
  },
  "graphify_output_dir": "runs/graphify",
  "obsidian_vault_dir": "runs/vault",
  "validation": {
    "python_min_share": 0.5,
    "min_file_count": 5,
    "max_file_count": 5000
  },
  "graphify": {
    "binary": "graphify",
    "stages": ["detect", "extract", "build", "cluster", "export"],
    "output_root": "runs/graphify",
    "timeout_s": 600,
    "analysis_depth": "structural",
    "token_budget": 100000,
    "llm_backend": "gemini",
    "llm_model": "gemini-2.0-flash-lite"
  },
  "vault": {
    "vault_root": "runs/vault",
    "raw_dir_name": "raw",
    "wiki_dir_name": "wiki",
    "hot_top_n": 10,
    "index_read_first_count": 3
  },
  "analysis": {
    "confidence_floor": 0.55,
    "confidence_strong": 0.95,
    "duplicate_similarity_threshold": 0.91
  },
  "deliverables": {
    "output_dir": "deliverables",
    "mermaid_direction": "TD",
    "match_confidence_threshold": 0.55
  },
  "sdk": {
    "default_analysis_depth": "structural",
    "plugin_allowlist": [],
    "vault_output_root": "runs/vault",
    "checkpoint_db": "runs/checkpoints.sqlite"
  },
  "improvement_loop": {
    "max_iterations": 5,
    "priority_order": ["P1", "P2", "P3", "P4", "P5"],
    "allowed_evidence_levels": ["EXTRACTED", "VALIDATED"],
    "branch_prefix": "fix/iter"
  },
  "metrics": {
    "output_dir": "metrics/out",
    "baseline_ledger": "baseline_ledger.jsonl",
    "assisted_ledger": "assisted_ledger.jsonl",
    "metrics_json": "token_metrics.json",
    "savings_target_pct": 70.0,
    "max_wiki_pages": 3,
    "default_model": "claude-opus-4-8"
  },
  "pricing": {
    "claude-opus-4-8": {"input_per_mtok": 5.0, "output_per_mtok": 25.0},
    "claude-sonnet-4-6": {"input_per_mtok": 3.0, "output_per_mtok": 15.0},
    "claude-haiku-4-5": {"input_per_mtok": 1.0, "output_per_mtok": 5.0},
    "gpt-4o": {"input_per_mtok": 2.5, "output_per_mtok": 10.0},
    "gpt-4o-mini": {"input_per_mtok": 0.15, "output_per_mtok": 0.6}
  },
  "knowledge_assets": {
    "raw_dir": "raw",
    "wiki_dir": "wiki",
    "skills_dir": "skills",
    "eval_task_set": "config/eval_tasks.json",
    "metrics_output": "metrics/out"
  },
  "sensitivity": {
    "run_count": 3,
    "analysis_depth": ["structural", "semantic"],
    "top_k_pages": [1, 2, 3, 4, 5],
    "rate_limit_rpm": [10, 30, 60],
    "similarity_threshold": [0.85, 0.88, 0.91, 0.94],
    "baseline": {"analysis_depth": "structural", "top_k_pages": 3, "rate_limit_rpm": 30, "similarity_threshold": 0.91}
  },
  "suggested_repos": [
    {"name": "httpie", "url": "https://github.com/httpie/cli", "note": "approved primary target (BSD-3, 133 .py)"},
    {"name": "requests", "url": "https://github.com/psf/requests", "note": "approved fallback (Apache-2.0)"},
    {"name": "click", "url": "https://github.com/pallets/click", "note": "modern pyproject, uv-friendly"},
    {"name": "tqdm", "url": "https://github.com/tqdm/tqdm", "note": "BugsInPy registry; small (69 .py)"},
    {"name": "BugsInPy", "url": "https://github.com/soarsmu/BugsInPy", "note": "lecturer suggestion: real field bugs"}
  ]
}
