{
  "version": "1.00",
  "target_repo": {
    "url": "https://github.com/httpie/cli",
    "branch": "master",
    "pinned_commit": "HEAD",
    "workdir_root": "runs",
    "clone_depth": 1,
    "timeout_s": 300,
    "max_size_mb": 200
  },
  "fallback_repo": {
    "url": "https://github.com/psf/requests",
    "branch": "main",
    "pinned_commit": "HEAD",
    "workdir_root": "runs",
    "clone_depth": 1,
    "timeout_s": 300,
    "max_size_mb": 200
  },
  "graphify_output_dir": "runs/graphify",
  "obsidian_vault_dir": "runs/vault",
  "validation": {
    "python_min_share": 0.5,
    "min_file_count": 5,
    "max_file_count": 5000
  },
  "graphify": {
    "binary": "graphify",
    "stages": ["detect", "extract", "build", "cluster", "export"],
    "output_root": "runs/graphify",
    "timeout_s": 600,
    "analysis_depth": "structural",
    "token_budget": 100000
  },
  "vault": {
    "vault_root": "runs/vault",
    "raw_dir_name": "raw",
    "wiki_dir_name": "wiki",
    "hot_top_n": 10,
    "index_read_first_count": 3
  },
  "analysis": {
    "confidence_floor": 0.55,
    "confidence_strong": 0.95,
    "duplicate_similarity_threshold": 0.91
  },
  "deliverables": {
    "output_dir": "deliverables",
    "mermaid_direction": "TD",
    "match_confidence_threshold": 0.55
  },
  "sdk": {
    "default_analysis_depth": "structural",
    "plugin_allowlist": [],
    "vault_output_root": "runs/vault",
    "checkpoint_db": "runs/checkpoints.sqlite"
  },
  "improvement_loop": {
    "max_iterations": 5,
    "priority_order": ["P1", "P2", "P3", "P4", "P5"],
    "allowed_evidence_levels": ["EXTRACTED", "VALIDATED"],
    "branch_prefix": "fix/iter"
  },
  "metrics": {
    "output_dir": "metrics/out",
    "baseline_ledger": "baseline_ledger.jsonl",
    "assisted_ledger": "assisted_ledger.jsonl",
    "metrics_json": "token_metrics.json",
    "savings_target_pct": 70.0,
    "max_wiki_pages": 3,
    "default_model": "claude-opus-4-8"
  },
  "pricing": {
    "claude-opus-4-8": {"input_per_mtok": 5.0, "output_per_mtok": 25.0},
    "claude-sonnet-4-6": {"input_per_mtok": 3.0, "output_per_mtok": 15.0},
    "claude-haiku-4-5": {"input_per_mtok": 1.0, "output_per_mtok": 5.0}
  }
}
