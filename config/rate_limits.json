{
  "version": "1.00",
  "rate_limits": {
    "services": {
      "default": {
        "requests_per_minute": 30,
        "requests_per_hour": 500,
        "concurrent_max": 5,
        "retry_after_seconds": 30,
        "max_retries": 3
      }
    }
  },
  "queue": {
    "max_depth": 100,
    "backpressure_warn_ratio": 0.8
  }
}
