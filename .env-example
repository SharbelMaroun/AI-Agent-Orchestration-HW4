# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).
# Set ONE agent-provider key. The gatekeeper auto-detects the provider from whichever key is present
# (OpenAI when only an OpenAI key is set, else Anthropic); ARCHLENS_LLM_PROVIDER forces the choice.

# --- OpenAI (the shipped default: config/setup.json uses gpt-4.1-mini) ---
OPENAI_API_KEY=sk-openai-dummy-key-replace-me
ARCHLENS_LLM_MODEL=gpt-4.1-mini

# --- Anthropic (use instead of OpenAI; set ONE of these and a Claude model below) ---
# ANTHROPIC_API_KEY=sk-ant-dummy-key-replace-me
# ANTHROPIC_AUTH_TOKEN=sk-ant-dummy-oauth-token-replace-me   # alternative to ANTHROPIC_API_KEY
# ARCHLENS_LLM_MODEL=claude-opus-4-8

# Optional overrides:
# ARCHLENS_LLM_PROVIDER=openai   # force a provider (auto | anthropic | openai)
# ARCHLENS_LLM_MODE=mock         # force offline mock (auto | live | mock)

# --- Graphify SEMANTIC pass (separate from our agents; community-naming via graphify label) ---
# Shipped default backend is OpenAI gpt-4.1-mini (config/setup.json graphify.llm_backend/llm_model);
# a GEMINI_API_KEY backend is also supported. Needs graphify.analysis_depth="semantic".
# GEMINI_API_KEY=gemini-dummy-key-replace-me

GITHUB_TOKEN=ghp_dummy_token_replace_me
