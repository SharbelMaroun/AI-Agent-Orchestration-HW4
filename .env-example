# Copy to .env and fill in real values. NEVER commit .env (it is git-ignored).
# Set ONE provider key. The gatekeeper auto-detects the provider from whichever key is present.

# --- Anthropic (default provider) ---
ANTHROPIC_API_KEY=sk-ant-dummy-key-replace-me

# --- OpenAI (set this instead, and pick a matching model below) ---
# OPENAI_API_KEY=sk-openai-dummy-key-replace-me
# ARCHLENS_LLM_MODEL=gpt-4o

# Optional overrides:
# ARCHLENS_LLM_PROVIDER=openai   # force a provider (auto | anthropic | openai)
# ARCHLENS_LLM_MODE=mock         # force offline mock (auto | live | mock)

GITHUB_TOKEN=ghp_dummy_token_replace_me
